# Environment example for Linux/Tailscale deployment

# Required API credentials
ANTHROPIC_API_KEY=
APIFY_TOKEN=

# Optional model/runtime overrides
YT_LLM_PROVIDER=anthropic
YT_LLM_MODEL=claude-opus-4-7
ANTHROPIC_BASE_URL=https://api.anthropic.com
YT_EMBEDDING_MODEL=all-MiniLM-L6-v2
YT_TRANSCRIPT_PROVIDER=auto
YT_WATCH_INTERVAL_SECONDS=600
YT_WINDOW=5

# Runtime paths
YT_STATE_DIR=/srv/ai-hub/workspaces/yt-strategy-agent/runtime
YT_OUTPUT_DIR=/srv/ai-hub/workspaces/yt-strategy-agent/runtime/channels
YT_DB_PATH=/srv/ai-hub/workspaces/yt-strategy-agent/runtime/state.db
YT_TOKEN_PATH=/srv/ai-hub/workspaces/yt-strategy-agent/runtime/token.pickle
YT_LOG_DIR=/srv/ai-hub/workspaces/yt-strategy-agent/runtime/logs
YT_CHANNELS_FILE=/srv/ai-hub/workspaces/yt-strategy-agent/channels.yaml
YT_CLIENT_SECRET=/srv/ai-hub/workspaces/yt-strategy-agent/client_secret.json

# Email alerts
YT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# Optional tailscale metadata for operators
TAILSCALE_HOSTNAME=
TAILSCALE_TAILNET=
